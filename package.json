{
  "name": "food-delivery-root",
  "version": "1.0.0",
  "description": "Full-stack food delivery application using MERN stack",
  "main": "index.js",
  "scripts": {
    "backend-install": "npm install --prefix backend",
    "frontend-install": "npm install --prefix frontend",
    "install-all": "npm install && npm run backend-install && npm run frontend-install",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
